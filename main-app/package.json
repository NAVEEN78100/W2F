{
    "name": "main-app",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "dev:web": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "seed": "node ../backend/seed.js",
        "api": "node ../backend/server.js",
        "dev:api": "node ../backend/server.js",
        "dev:help": "npm --prefix ../help-hub run dev",
        "dev:dashboard": "npm --prefix ../dashboard run dev",
        "dev:all": "concurrently -n API,WEB,HELP,DASH -c green,cyan,magenta,yellow \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:help\" \"npm run dev:dashboard\"",
        "stop:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/stop-all.ps1",
        "restart:all": "npm run stop:all && npm run dev:all",
        "setup:all": "npm install && npm --prefix ../backend install && npm --prefix ../help-hub install && npm --prefix ../dashboard install && npm run seed"
    },
    "dependencies": {
        "@gsap/react": "^2.1.2",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "autoprefixer": "^10.4.23",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "finalwwf-monorepo": "file:..",
        "framer-motion": "^12.27.5",
        "gsap": "^3.14.2",
        "lucide-react": "^0.562.0",
        "mongodb": "^7.0.0",
        "motion": "^12.27.5",
        "next": "^16.1.1",
        "next-themes": "^0.4.6",
        "nodemailer": "^8.0.1",
        "postcss": "^8.5.6",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "tailwind-merge": "^3.4.0",
        "tailwindcss-animate": "^1.0.7",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@types/node": "25.0.9",
        "@types/nodemailer": "^7.0.11",
        "@types/react": "19.2.8",
        "concurrently": "^9.2.1",
        "tailwindcss": "^3.3.3",
        "typescript": "5.9.3"
    }
}
